{
  "name": "@oxwmay-labs/mtools",
  "version": "0.1.0",
  "description": "Set of useful utilities for development",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -w -p ./",
